# FINBOT-9000 Environment Variables
# Copy this file to .env and fill in your values
# Usage: cp .env.example .env

# Anthropic API key — get one at console.anthropic.com
# Without this key, the game runs in OFFLINE MODE with 12 curated fallback scenarios
VITE_ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Supabase leaderboard — optional. Without these, leaderboard uses localStorage only.
# 1. Create a free project at supabase.com
# 2. Run the schema SQL from src/engine/supabase.js comments
# 3. Copy your project URL and anon key from Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Sentry error tracking — optional. Sign up free at sentry.io
# Create a Browser JavaScript project, copy the DSN from Project Settings > Client Keys
VITE_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# Obsidian vault file path for the sync server (obsidian-sync.js)
# Default: ~/Obsidian/FINBOT-9000.md
OBSIDIAN_VAULT_FILE=/home/hlnx4/Obsidian/FINBOT-9000.md
